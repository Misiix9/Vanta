{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vanta",
  "version": "5.13.0",
  "identifier": "dev.vanta.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vanta",
        "width": 680,
        "height": 420,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data: blob: stream: https://raw.githubusercontent.com https://i.scdn.co https://*.scdn.co; font-src 'self'; connect-src 'self' asset: https://raw.githubusercontent.com https://api.github.com;",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "/usr/share/icons/**",
          "/usr/share/pixmaps/**",
          "/usr/local/share/icons/**",
          "/usr/local/share/pixmaps/**",
          "/var/lib/flatpak/exports/share/icons/**",
          "/var/lib/flatpak/exports/share/pixmaps/**",
          "/var/lib/snapd/desktop/icons/**",
          "/snap/**",
          "/opt/**",
          "/run/current-system/sw/share/icons/**",
          "/nix/store/**",
          "$HOME/.local/share/icons/**",
          "$HOME/.local/share/pixmaps/**",
          "$HOME/.local/share/flatpak/exports/share/icons/**",
          "$HOME/.icons/**",
          "/var/lib/flatpak/app/**",
          "$HOME/.config/vanta/extensions/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "resources": {
      "resources/themes/base.css": "themes/base.css",
      "resources/themes/default.css": "themes/default.css",
      "resources/themes/universal.css": "themes/universal.css"
    },
    "targets": [
      "deb",
      "rpm"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
